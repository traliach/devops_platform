# AWS key pair — created from the public key generated by scripts/setup-prerequisites.sh
# The private key never touches AWS; only the public key is uploaded here
resource "aws_key_pair" "deployer" {
  count      = var.public_key != null ? 1 : 0
  key_name   = var.project
  public_key = var.public_key
}

# Latest Amazon Linux 2023 AMI — never hardcode the AMI ID
# Data source always resolves to the current latest for the region
data "aws_ami" "al2023" {
  most_recent = true
  owners      = ["amazon"]

  filter {
    name   = "name"
    values = ["al2023-ami-*-x86_64"]
  }

  filter {
    name   = "virtualization-type"
    values = ["hvm"]
  }
}

# EC2 instance — the single server running the entire platform
resource "aws_instance" "platform" {
  ami                    = data.aws_ami.al2023.id
  instance_type          = var.instance_type
  key_name               = var.public_key != null ? aws_key_pair.deployer[0].key_name : null
  subnet_id              = aws_subnet.public.id
  vpc_security_group_ids = [aws_security_group.platform.id]
  iam_instance_profile   = aws_iam_instance_profile.ec2.name

  root_block_device {
    volume_type           = "gp3"
    volume_size           = var.root_volume_size_gb
    delete_on_termination = true
    encrypted             = true
  }

  # Prevent accidental destruction — use stop/start for cost control, not destroy
  lifecycle {
    prevent_destroy = true
  }

  tags = { Name = "${var.project}-server" }
}
