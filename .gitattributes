# Enforce LF line endings for all text files
* text=auto eol=lf

# Shell scripts must always be LF — CRLF breaks bash on Linux
*.sh text eol=lf

# Ansible/YAML must be LF
*.yml text eol=lf
*.yaml text eol=lf

# Terraform must be LF
*.tf text eol=lf
*.tfvars text eol=lf

# Makefile must be LF
Makefile text eol=lf

# Windows-specific files can use CRLF
*.bat text eol=crlf
*.cmd text eol=crlf
