# platform/.env.example
# Copy to .env and fill in values before running docker compose up
# .env is gitignored — never commit it
#
# cp .env.example .env

# ── Grafana ───────────────────────────────────────────────────────────────────
# Admin credentials — change from defaults before first run
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme_use_strong_password

# ── Jenkins ──────────────────────────────────────────────────────────────────
# Jenkins admin user password — set via JCasC, change before first run
JENKINS_ADMIN_PASSWORD=changeme_use_strong_password

# ── Flask app + GHCR ─────────────────────────────────────────────────────────
# GitHub Container Registry username (used to pull the Flask app image)
GHCR_USERNAME=traliach

# GHCR token — used by Jenkins to push the Flask app image
# Same token set in GitHub Actions secrets by setup-prerequisites.sh
GHCR_TOKEN=your_ghcr_token_here

# Flask app image version tag — set by Jenkins pipeline on deploy
# Use 'latest' only for local testing, never in production
FLASK_APP_VERSION=latest
