# platform/.env.example
# Copy to .env and fill in values before running docker compose up
# .env is gitignored — never commit it
#
# cp .env.example .env

# ── Grafana ───────────────────────────────────────────────────────────────────
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme_use_strong_password

# ── Jenkins ──────────────────────────────────────────────────────────────────
JENKINS_ADMIN_PASSWORD=changeme_use_strong_password

# ── Manga Hub + GHCR ─────────────────────────────────────────────────────────
# GitHub Container Registry username — used to pull/push the manga-hub image
GHCR_USERNAME=traliach

# GHCR personal access token — needs read:packages + write:packages scopes
# Generate at: GitHub → Settings → Developer settings → Personal access tokens
GHCR_TOKEN=your_ghcr_token_here

# manga-hub image version tag — set by Jenkins pipeline on each build
# Use 'latest' only for local testing
APP_VERSION=latest
